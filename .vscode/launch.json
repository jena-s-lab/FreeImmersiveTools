{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Client (Debug)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/latest/Vintagestory.exe",
            "linux": {
                "program": "${workspaceFolder}/bin/latest/Vintagestory"
            },
            "osx": {
                "program": "${workspaceFolder}/bin/latest/Vintagestory"
            },
            "preLaunchTask": "build",
            "env": {
                "VINTAGE_STORY": "${workspaceFolder}/bin/latest",
                "FONTCONFIG_FILE": "${workspaceFolder}/bin/latest/fonts.conf"
            },
            "cwd": "${workspaceFolder}/bin/latest",
            "args": [
                // "--playStyle" , "preset-surviveandbuild",
                // "--openWorld" , "modding test world",
                "--tracelog",
                "--addModPath",
                "${workspaceFolder}/FreeImmersiveTools/bin/Debug/Mods"
            ],
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Launch Server",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/latest/VintagestoryServer.exe",
            "linux": {
                "program": "${workspaceFolder}/bin/latest/VintagestoryServer"
            },
            "osx": {
                "program": "${workspaceFolder}/bin/latest/VintagestoryServer"
            },
            "preLaunchTask": "build",
            "env": {
                "VINTAGE_STORY": "${workspaceFolder}/bin/latest"
            },
            "cwd": "${workspaceFolder}/bin/latest",
            "args": [
                "--tracelog",
                "--addModPath",
                "${workspaceFolder}/FreeImmersiveTools/bin/Debug/Mods"
            ],
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "CakeBuild",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build (Cake)",
            "env": {
                "VINTAGE_STORY": "${workspaceFolder}/bin/latest"
            },
            "program": "${workspaceFolder}/CakeBuild/bin/Debug/net10.0/CakeBuild.dll",
            "args": [],
            "cwd": "${workspaceFolder}/CakeBuild",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "Start VS task + Attach",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/latest/Vintagestory.dll",
            "args": [
                "--addModPath",
                "${workspaceFolder}/bin/Debug/Mods/mod",
                "--openWorld",
                "mod-testing",
                "--playStyle",
                "creativebuilding",
                "--tracelog"
            ],
            "cwd": "${workspaceFolder}/bin/vs",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}